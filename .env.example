# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed (PRD 9.3). These are also the secrets to set in Vercel for
# production (PRD 5.5, 9.3).

# Neon Postgres connection string (pooled or direct). TLS is required, so keep
# the sslmode parameter.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# OpenRouter (all model calls: Sonnet planning/synthesis, Haiku scoring/extract).
OPENROUTER_API_KEY="sk-or-..."

# Tavily web search + extraction.
TAVILY_API_KEY="tvly-..."

# Reddit app-only OAuth (script app).
REDDIT_CLIENT_ID="..."
REDDIT_CLIENT_SECRET="..."

# Better Auth (PRD 8). Generate the secret with: openssl rand -base64 32
# BETTER_AUTH_URL is the app's base URL (e.g. https://your-app.vercel.app in prod).
BETTER_AUTH_SECRET="a-long-random-secret-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth client (Google Cloud Console). Authorised redirect URI must be
# <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="..."
